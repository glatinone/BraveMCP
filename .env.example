# BraveMCP - Environment Configuration Example
# Copy this file to .env and configure as needed

# AI Provider options: "ollama" or "anthropic"
AI_PROVIDER=ollama

# Local Ollama endpoint
OLLAMA_URL=http://localhost:11434

# Anthropic API Key (required if AI_PROVIDER=anthropic or for Anthropic fallbacks)
ANTHROPIC_API_KEY=your-key-here
